###########################
# USP Controller Dashboard
# Copy this file to `.env` and fill in values for your environment.
###########################

# URL for your PostgreSQL or SQLite database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# MQTT broker configuration
MQTT_BROKER_URL="mqtt://localhost:1883"
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_TLS="false"

# Identifier for this controller.  Should be unique per deployment (used as ClientId when empty)
USP_CONTROLLER_ID="usp-controller-1"

# NextAuth configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-random-secret"

# WebSocket URL (defaults to same host)
NEXT_PUBLIC_WS_URL=""

# Prisma
PRISMA_SCHEMA_ENGINE_EXIT="1"
